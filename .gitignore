# Dependencies
node_modules/

# Build outputs (we COMMIT dist/index.js for the GitHub Action)
# Only ignore dist/ subdirectories that aren't the action bundle
.tsbuildinfo
*.tsbuildinfo

# Test outputs
coverage/
.vitest-cache/

# Local env
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*

# Private golden-dataset safety net.
# The real dataset lives in a SEPARATE PRIVATE repo (e.g. vor-golden),
# discovered via the GOLDEN_REPO_PATH env var. These patterns exist so that if
# anything from that workflow ever lands inside this repo, it cannot be staged
# by accident. See docs/golden-dataset.md.
/golden/
/golden-dataset/
/vor-golden/
/eval-reports/
*.golden.json
