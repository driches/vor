{
  "name": "@driches/code-review",
  "version": "0.1.0",
  "description": "AI code review GitHub Action — inline comments via Claude Agent SDK",
  "license": "MIT",
  "author": "Doug Riches",
  "homepage": "https://github.com/driches/code-review",
  "repository": {
    "type": "git",
    "url": "https://github.com/driches/code-review.git"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsx scripts/build.ts",
    "verify-dist": "tsx scripts/verify-dist.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "record-fixture": "tsx scripts/record-fixture.ts"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@anthropic-ai/claude-agent-sdk": "^0.1.10",
    "@anthropic-ai/sdk": "^0.39.0",
    "@octokit/plugin-retry": "^7.1.4",
    "@octokit/plugin-throttling": "^9.4.0",
    "@octokit/rest": "^21.1.1",
    "parse-diff": "^0.11.1",
    "yaml": "^2.7.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "esbuild": "^0.24.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
